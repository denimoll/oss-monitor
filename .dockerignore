# Version control
.git
.github
.gitignore

# Claude / editor artifacts
.claude

# Python cache
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache
**/.mypy_cache

# Test & dev-only files (not needed in production image)
backend/tests/
backend/pytest.ini
backend/requirements-test.txt

# Documentation & examples (not needed in image)
*.md
examples/

# Environment files (never bake secrets into images)
**/.env
**/.env.*

# OS artifacts
.DS_Store
Thumbs.db
